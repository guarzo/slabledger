# ==============================================================================
# Docker Configuration (for production deployment)
# ==============================================================================
DOCKERHUB_USERNAME=guarzo
VERSION=latest

# ==============================================================================
# Required API Tokens
# ==============================================================================
PRICECHARTING_TOKEN=your_pricecharting_token_here
PSA_ACCESS_TOKEN=your_psa_token_here

# ==============================================================================
# Google OAuth Configuration (REQUIRED for multi-user production)
# ==============================================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8081/auth/google/callback

# ==============================================================================
# Security Configuration (REQUIRED for production)
# ==============================================================================
# Generate with: openssl rand -hex 32
# WARNING: Using the placeholder below in production WILL BREAK encryption!
ENCRYPTION_KEY=DO_NOT_USE_IN_PRODUCTION

# ==============================================================================
# Optional: Multi-Source Price Fusion
# ==============================================================================
# PokemonPriceTracker (primary graded price source via eBay smartMarketPrice)
POKEMONPRICE_TRACKER_API_KEY=your_api_key

# CardHedger (supplementary pricing — multi-platform estimates, unlimited plan)
CARD_HEDGER_API_KEY=your_api_key

# ==============================================================================
# Database Configuration
# ==============================================================================
DATABASE_PATH=data/slabledger.db

# ==============================================================================
# Background Scheduler Configuration
# ==============================================================================
PRICE_REFRESH_INTERVAL=1h
PRICE_BATCH_SIZE=50
PRICE_BATCH_DELAY=1s
PRICE_MAX_BURST_CALLS=10
SESSION_CLEANUP_INTERVAL=1h

# ==============================================================================
# Server Configuration
# ==============================================================================
LOG_JSON=false
LOG_LEVEL=info
PORT=8081
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_TRUST_PROXY=false

