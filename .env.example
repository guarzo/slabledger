# =============================================================================
# SlabLedger Environment Configuration
# Copy this file to .env and fill in your values.
# Lines marked REQUIRED must be set for the feature to work.
# Lines marked OPTIONAL use the shown default when unset.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication — Google OAuth 2.0
# REQUIRED for login. Generate credentials in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8081/auth/google/callback"

# Controls whether OAuth session cookies use the Secure flag.
# Set to "development" or "dev" to disable Secure cookies on plain HTTP.
# OPTIONAL (default: production mode — Secure cookies always on)
GOOGLE_OAUTH_ENV=""

# -----------------------------------------------------------------------------
# Authentication — Token Encryption
# REQUIRED for storing OAuth tokens encrypted in the database (AES-256-GCM).
# Generate with: openssl rand -hex 32
# WARNING: Never commit a real key. DO NOT use a placeholder in production.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=""

# Comma-separated list of email addresses that always have admin privileges.
# OPTIONAL
ADMIN_EMAILS=""

# Bearer token for CLI / curl access without browser OAuth.
# OPTIONAL
LOCAL_API_TOKEN=""

# -----------------------------------------------------------------------------
# Pricing — External API Keys
# -----------------------------------------------------------------------------

# PSA API keys (comma-separated for rotation). Used for cert lookup and DH cert
# resolution (via X-PSA-API-Key header).
# OPTIONAL
PSA_ACCESS_TOKEN=""

# Bearer token for the internal pricing REST API (machine-to-machine access).
# OPTIONAL
PRICING_API_KEY=""

# -----------------------------------------------------------------------------
# AI — Azure OpenAI (Advisor + Social Caption Generation)
# All three must be set together to enable AI features.
# OPTIONAL
# -----------------------------------------------------------------------------
AZURE_AI_ENDPOINT=""
AZURE_AI_API_KEY=""
AZURE_AI_DEPLOYMENT="gpt-5.4"
# AZURE_AI_TIMEOUT="3m"   # Completion poll fallback timeout (default 3m; e.g. "90s", "5m")

# -----------------------------------------------------------------------------
# Instagram OAuth (Social Content Publishing)
# REQUIRED for Instagram carousel publishing.
# Social content is disabled by default; set SOCIAL_CONTENT_ENABLED=true to use.
# -----------------------------------------------------------------------------
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_REDIRECT_URI="http://localhost:8081/auth/instagram/callback"

# -----------------------------------------------------------------------------
# Social Content Scheduler
# OPTIONAL
# -----------------------------------------------------------------------------
SOCIAL_CONTENT_ENABLED="false"
SOCIAL_CONTENT_INTERVAL="24h"
SOCIAL_CONTENT_INITIAL_DELAY="5m"

# Public base URL for slide generation, media URLs, and AI background tasks.
# OPTIONAL — slide URLs will be derived from request headers if not set.
# Example: https://slabledger.example.com
BASE_URL=""

# -----------------------------------------------------------------------------
# Auto Instagram Publishing
# Set RENDER_SERVICE_URL to enable automatic publishing. Leave empty to disable.
# OPTIONAL
# -----------------------------------------------------------------------------
# URL of the Puppeteer render sidecar (set to enable auto-publishing)
RENDER_SERVICE_URL=""
# Publishing window (server local time, 0-23)
SOCIAL_PUBLISH_START_HOUR="9"
SOCIAL_PUBLISH_END_HOUR="21"
# How often to check for pending drafts (minutes)
SOCIAL_PUBLISH_INTERVAL_MINUTES="60"
# Max posts to auto-publish per calendar day
AUTO_PUBLISH_MAX_DAILY="10"

# -----------------------------------------------------------------------------
# Instagram Metrics Polling
# OPTIONAL
# -----------------------------------------------------------------------------
# Enable/disable Instagram metrics collection
METRICS_POLL_ENABLED="false"
# How often to poll (default: 6h)
METRICS_POLL_INTERVAL="6h"
# Maximum age of posts to poll metrics for (default: 168h / 7 days)
METRICS_POLL_MAX_AGE="168h"

# Directory where uploaded media files are stored.
# OPTIONAL (default: ./data/media)
MEDIA_DIR=""

# -----------------------------------------------------------------------------
# HTTP Server
# OPTIONAL
# -----------------------------------------------------------------------------
HTTP_LISTEN_ADDR=""
HTTP_READ_TIMEOUT="15s"
HTTP_WRITE_TIMEOUT="90s"
HTTP_IDLE_TIMEOUT="60s"
# Graceful scheduler shutdown timeout in seconds (default: 30)
# SHUTDOWN_TIMEOUT_SECONDS=30

# Max requests per minute per IP before rate-limiting kicks in.
# OPTIONAL (default: 300)
RATE_LIMIT_REQUESTS="300"

# Trust X-Forwarded-For and X-Real-IP headers (set true when behind a reverse proxy).
# OPTIONAL (default: false)
RATE_LIMIT_TRUST_PROXY="false"

# Comma-separated list of additional CORS origins beyond the localhost defaults.
# OPTIONAL
ALLOWED_ORIGIN=""

# -----------------------------------------------------------------------------
# Logging
# OPTIONAL
# -----------------------------------------------------------------------------
LOG_LEVEL="info"
LOG_JSON="false"

# -----------------------------------------------------------------------------
# Database
# OPTIONAL
# -----------------------------------------------------------------------------
DATABASE_PATH="data/slabledger.db"

# Override the embedded migrations with an external directory path.
# OPTIONAL — leave empty to use migrations bundled in the binary.
MIGRATIONS_PATH=""

# -----------------------------------------------------------------------------
# Maintenance — Access Log Cleanup
# OPTIONAL
# -----------------------------------------------------------------------------
ACCESS_LOG_CLEANUP_ENABLED="true"
ACCESS_LOG_RETENTION_DAYS="30"
ACCESS_LOG_CLEANUP_INTERVAL="24h"

# -----------------------------------------------------------------------------
# Price Refresh Scheduler
# OPTIONAL
# -----------------------------------------------------------------------------
PRICE_REFRESH_ENABLED="true"
PRICE_REFRESH_INTERVAL="1h"
PRICE_BATCH_SIZE="100"
PRICE_BATCH_DELAY="200ms"
PRICE_MAX_BURST_CALLS="50"
PRICE_MAX_CALLS_PER_HOUR="400"
PRICE_BURST_PAUSE_DURATION="10s"

# -----------------------------------------------------------------------------
# Session Cleanup Scheduler
# OPTIONAL
# -----------------------------------------------------------------------------
SESSION_CLEANUP_ENABLED="true"
SESSION_CLEANUP_INTERVAL="1h"

# -----------------------------------------------------------------------------
# DH — Market Intelligence & Pricing
# OPTIONAL — requires DH_API_BASE_URL and DH_ENTERPRISE_API_KEY
# -----------------------------------------------------------------------------
DH_API_BASE_URL=""
DH_CACHE_TTL_HOURS="24"
DH_ENABLED="true"

# Enterprise API key for authenticating DH requests (cert resolution, inventory, orders).
# OPTIONAL — required for DH enterprise features.
DH_ENTERPRISE_API_KEY=""
DH_RATE_LIMIT_RPS="1"

# Poll interval for fetching order updates from DH (e.g., "30m", "1h").
# OPTIONAL (default: 30m)
DH_ORDERS_POLL_INTERVAL="30m"

# Poll interval for syncing inventory status from DH (e.g., "2h", "4h").
# OPTIONAL (default: 2h)
DH_INVENTORY_POLL_INTERVAL="2h"

# DH Enterprise Instagram Generation
# Enables DHSocialScheduler which creates up to 4 Instagram draft posts per day
# using DH's own_inventory strategies. Requires DH_ENTERPRISE_API_KEY to be set.
DH_SOCIAL_ENABLED=false
# UTC hour to run daily (0-23)
DH_SOCIAL_HOUR=6
# How often to poll DH while waiting for slide renders
DH_SOCIAL_POLL_INTERVAL=5s
# Max time to wait for DH to finish rendering slides
DH_SOCIAL_POLL_TIMEOUT=3m

# DH Demand Analytics refresh scheduler.
# Caches per-card and per-character demand + velocity + saturation signals from
# DH Enterprise (used by the niche-opportunity leaderboard). Disabled by default
# as a launch gate — enable once the DH impression pipeline is healthy.
DH_ANALYTICS_REFRESH_ENABLED=false
# UTC hour to run daily (0-23). Default 3 = 3am UTC, ~30min after DH's nightly
# analytics rollup (03:30 UTC) completes.
DH_ANALYTICS_REFRESH_HOUR=3
# Demand signal window passed to DH (e.g. "7d", "30d"). Default "30d".
DH_ANALYTICS_REFRESH_WINDOW=30d

# -----------------------------------------------------------------------------
# Market Movers (Sports Card Investor) — Integration credentials
# Used only by integration tests (go test -tags integration).
# Credentials are your sportscardinvestor.com WordPress login.
# At runtime, credentials are stored encrypted in the DB via the admin UI.
# OPTIONAL — only needed for: go test ./internal/integration/ -tags integration -run TestMarketMovers
# -----------------------------------------------------------------------------
MM_EMAIL=""
MM_PASSWORD=""

# -----------------------------------------------------------------------------
# Inventory Refresh Scheduler
# OPTIONAL
# -----------------------------------------------------------------------------
INVENTORY_REFRESH_ENABLED="true"
INVENTORY_REFRESH_INTERVAL="1h"
INVENTORY_REFRESH_STALE_THRESHOLD="12h"
INVENTORY_REFRESH_BATCH_SIZE="20"
INVENTORY_REFRESH_BATCH_DELAY="2s"

# -----------------------------------------------------------------------------
# Snapshot Enrichment Scheduler
# OPTIONAL
# -----------------------------------------------------------------------------
SNAPSHOT_ENRICH_ENABLED="true"
SNAPSHOT_ENRICH_INTERVAL="15s"
SNAPSHOT_ENRICH_BATCH_SIZE="3"
SNAPSHOT_ENRICH_RETRY_INTERVAL="30m"
SNAPSHOT_ENRICH_MAX_RETRIES="5"

# -----------------------------------------------------------------------------
# Advisor Refresh Scheduler (AI background portfolio analysis)
# OPTIONAL
# -----------------------------------------------------------------------------
ADVISOR_REFRESH_ENABLED="true"
ADVISOR_REFRESH_INTERVAL="24h"
ADVISOR_REFRESH_INITIAL_DELAY="2m"

# -----------------------------------------------------------------------------
# Card Ladder Refresh Scheduler (daily CL value sync)
# OPTIONAL
# -----------------------------------------------------------------------------
CARDLADDER_REFRESH_ENABLED="true"
CARDLADDER_REFRESH_HOUR="4"

# -----------------------------------------------------------------------------
# Market Movers Refresh Scheduler (daily MM value sync)
# OPTIONAL
# -----------------------------------------------------------------------------
MM_REFRESH_ENABLED="true"
MM_REFRESH_HOUR="5"

# -----------------------------------------------------------------------------
# Google Sheets API (Service Account)
# Used for automated imports from Google Sheets (e.g., PSA sync)
# OPTIONAL — only needed if PSA_SYNC_ENABLED=true
# -----------------------------------------------------------------------------
# Full JSON content of the service account key file (base64-encoded)
# Encode with: base64 -w0 < service-account.json
GOOGLE_SHEETS_CREDENTIALS_JSON=""
# Spreadsheet document ID (from the URL: docs.google.com/spreadsheets/d/{THIS_ID}/...)
GOOGLE_SHEETS_SPREADSHEET_ID=""
# Tab/sheet name (empty = first sheet)
GOOGLE_SHEETS_TAB_NAME=""

# -----------------------------------------------------------------------------
# PSA Sync Scheduler (daily import from Google Sheets)
# OPTIONAL — requires Google Sheets credentials above
# -----------------------------------------------------------------------------
PSA_SYNC_ENABLED="false"
PSA_SYNC_HOUR="10"
