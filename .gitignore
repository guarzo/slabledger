# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
.env-*
!.env.example

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# DevContainer - keep configuration, ignore runtime
.devcontainer/.env
.devcontainer/commandhistory/
.devcontainer/docker-compose.override.yml

# Project binary
/slabledger
pokeprice

# Build directories
dist/
build/

# Debug files
*.log
debug

# Temporary files
*.tmp
tmp/

# Config files
.claude.env

# Certificate and key files
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json

# Data files (all runtime data stored in ./data/)
data/
node_modules/

# Prevent cache from being created in test/cmd directories
cmd/**/data/

.claude/*
!.claude/commands/
!.claude/skills/
!.claude/overnight-config.yaml

web/node_modules

# Frontend build output
web/dist/

# Docker bind mount directories
/cache/
.superpowers/
.worktrees/
docs/superpowers/

# Private docs (sensitive business data, kept locally only)
docs/private/
.claude/commands/campaign-analysis.md

# Internal engineering docs (not for public consumption)
docs/AI_USAGE_AUDIT.md
docs/Issues.md
docs/CARD_LADDER_INTEGRATION.md
